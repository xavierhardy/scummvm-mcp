{
  "protocol": "Monkey MCP (scumm-monkey-mcp)",
  "protocolVersion": "2025-03-26",
  "transport": "stdio",
  "scope": "Monkey Island 1 (GID_MONKEY, GID_MONKEY_EGA, GID_MONKEY_VGA)",
  "activationConfig": "monkey_mcp=true",
  "mcpServers": {
    "scummvm-stdio": {
      "transport": "stdio",
      "command": "/full/path/to/scummvm",
      "args": [
        "-c",
        "/full/path/to/scummvm.ini",
        "--debugflags",
        "monkey_mcp,scumm",
        "--debuglevel",
        "11"
      ],
      "env": {},
      "cwd": null,
      "description": "Launch ScummVM and talk to its Monkey MCP bridge over stdin/stdout"
    },
    "scummvm-file": {
      "transport": "stdio-file",
      "command": "/full/path/to/docs/protocols/start_scummvm_fifo.sh",
      "stdinPath": "/path/to/mcp-in.fifo",
      "stdoutPath": "/path/to/mcp-out.fifo",
      "description": "Use named pipes (FIFOs). The client should spawn the provided command which starts ScummVM with stdin/stdout redirected to the FIFOs. Client then writes JSON-RPC requests to stdinPath and reads responses from stdoutPath. Replace command and paths with absolute paths on your system."
    }
  },
  "notes": "This bridge is opt-in and only active for Monkey Island 1. Communication is JSON-RPC 2.0 over lines on stdin/stdout.",
  "methods": {
    "initialize": {
      "description": "Initialize and declare server capabilities.",
      "params": {},
      "result": {
        "protocolVersion": "string",
        "capabilities": { "tools": { } },
        "serverInfo": { "name": "string", "version": "string" }
      }
    },
    "tools/list": {
      "description": "List available MCP tools exposed by the engine.",
      "params": {},
      "result": {
        "tools": [
          { "name": "string", "description": "string", "inputSchema": { } }
        ]
      }
    },
    "tools/call": {
      "description": "Call a tool by name. The params object must contain `name` and optional `arguments`.",
      "params": {
        "name": "string",
        "arguments": "object (tool-specific schema)"
      },
      "result": "object (tool-specific schema)"
    }
  },
  "tools": [
    {
      "name": "list_inventory",
      "description": "List all inventory items owned by the player.",
      "inputSchema": { "type": "object", "properties": {}, "additionalProperties": false },
      "outputSchema": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "string" },
                "objectId": { "type": "integer" },
                "name": { "type": "string" },
                "slot": { "type": "integer" }
              },
              "required": ["id","objectId","name","slot"]
            }
          }
        }
      }
    },
    {
      "name": "list_scene_interactables",
      "description": "List objects, people, places (walk boxes), and active verb choices in the current room.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "includePlaces": { "type": "boolean" },
          "includeChoices": { "type": "boolean" }
        },
        "additionalProperties": false
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "room": { "type": "integer" },
          "objects": { "type": "array" },
          "people": { "type": "array" },
          "places": { "type": "array" },
          "choices": { "type": "array" }
        }
      }
    },
    {
      "name": "execute_action",
      "description": "Execute a verb action. Use `verbId` or `action` to identify the verb; provide `targetId` and optional `withId`.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "verbId": { "type": "integer" },
          "action": { "type": "string" },
          "targetId": { "type": "string" },
          "withId": { "type": "string" }
        },
        "required": ["targetId"],
        "additionalProperties": false
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "queued": { "type": "boolean" },
          "verbId": { "type": "integer" },
          "objectA": { "type": "integer" },
          "objectB": { "type": "integer" }
        }
      }
    },
    {
      "name": "respond_to_choice",
      "description": "Choose a verb-slot style choice. Provide a `choiceId` (eg. 'choice:verbslot:5') or an `index` (0-based).",
      "inputSchema": {
        "type": "object",
        "properties": {
          "choiceId": { "type": "string" },
          "index": { "type": "integer" }
        },
        "additionalProperties": false
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "queued": { "type": "boolean" },
          "verbSlot": { "type": "integer" },
          "verbId": { "type": "integer" }
        }
      }
    },
    {
      "name": "move_to",
      "description": "Move ego to a walk-box target (`targetId`) or explicit coordinates (`x`,`y`).",
      "inputSchema": {
        "type": "object",
        "oneOf": [
          { "type": "object", "properties": { "targetId": { "type": "string" } }, "required": ["targetId"] },
          { "type": "object", "properties": { "x": { "type": "integer" }, "y": { "type": "integer" } }, "required": ["x","y"] }
        ],
        "additionalProperties": false
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "queued": { "type": "boolean" },
          "mode": { "type": "string" },
          "x": { "type": "integer" },
          "y": { "type": "integer" }
        }
      }
    },
    {
      "name": "read_latest_messages",
      "description": "Read recent dialogue and system messages gathered by the engine.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "sinceSeq": { "type": "integer" },
          "limit": { "type": "integer" }
        },
        "additionalProperties": false
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "messages": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "seq": { "type": "integer" },
                "room": { "type": "integer" },
                "type": { "type": "string" },
                "actorId": { "type": "integer" },
                "text": { "type": "string" }
              },
              "required": ["seq","room","type","actorId","text"]
            }
          },
          "latestSeq": { "type": "integer" }
        }
      }
    }
  ],
  "examples": {
    "initialize": {
      "request": { "jsonrpc": "2.0", "id": 1, "method": "initialize", "params": {} },
      "response": { "jsonrpc": "2.0", "id": 1, "result": { "protocolVersion": "2025-03-26", "serverInfo": { "name": "scumm-monkey-mcp", "version": "0.1" } } }
    },
    "tools_list": {
      "request": { "jsonrpc": "2.0", "id": 2, "method": "tools/list", "params": {} },
      "response": { "jsonrpc": "2.0", "id": 2, "result": { "tools": [] } }
    },
    "tool_call": {
      "request": { "jsonrpc": "2.0", "id": 3, "method": "tools/call", "params": { "name": "list_inventory" } },
      "response": { "jsonrpc": "2.0", "id": 3, "result": { "items": [] } }
    }
  }
}
